---
import Layout from '../../layouts/Layout.astro';
import { weeks, getWeekBySlug } from '../../data/curriculum';

export function getStaticPaths() {
  return weeks.map(w => ({ params: { id: w.slug } }));
}

const { id } = Astro.params;
const week = getWeekBySlug(id!);
if (!week) return Astro.redirect('/');

const base = import.meta.env.BASE_URL;
const pdfFile = week.pptxFile.replace('.pptx', '.pdf');
const driveId = week.pptxDriveId;
const pdfUrl = driveId ? `https://drive.google.com/file/d/${driveId}/preview` : null;

const prevWeek = weeks.find(w => w.id === week.id - 1);
const nextWeek = weeks.find(w => w.id === week.id + 1);

const sectionColorClass: Record<string, string> = {
  'DERİN ÖĞRENME TEMELLERİ':   'bg-accent',
  'KERAS İLE UYGULAMA':        'bg-secondary',
  'İLERİ BİLGİSAYARLI GÖRÜ':   'bg-primary',
};
const badgeBg = sectionColorClass[week.section] ?? 'bg-mid';
---

<Layout
  title={`Uygulama ${week.id}: ${week.title}`}
  description={`${week.section} — ${week.title}. ${week.topics.slice(0,3).join(', ')} ve daha fazlası. Dr. Murat Altun, MEB YEĞİTEK Derin Öğrenme Serisi.`}
  activeWeekId={week.id}
  canonical={`https://drmurataltun.github.io/meb-yegitek-derin-ogrenme/hafta/${week.slug}/`}
>

  <!-- BREADCRUMB -->
  <div class="flex items-center gap-2 text-xs text-mid mb-4">
    <a href={base} class="hover:text-primary transition-colors">Program</a>
    <span>›</span>
    <span class={`px-2 py-0.5 rounded-full text-white text-[10px] font-bold ${badgeBg}`}>{week.section}</span>
    <span>›</span>
    <span class="text-dark font-medium">Uygulama {week.id}</span>
  </div>

  <!-- HEADER -->
  <div class="mb-6">
    <div class="flex items-start justify-between flex-wrap gap-3">
      <div>
        <span class={`inline-block text-[10px] font-bold uppercase tracking-wider text-white px-2 py-0.5 rounded ${badgeBg} mb-2`}>
          UYGULAMA {week.id} · {week.hours} SAAT
        </span>
        <h1 class="text-2xl font-bold text-dark leading-snug">{week.title}</h1>
        <p class="text-mid text-sm mt-1">{week.subtitle}</p>
      </div>
      <!-- Nav ok -->
      <div class="flex gap-2">
        {prevWeek && (
          <a href={`${base}hafta/${prevWeek.slug}`} class="flex items-center gap-1 text-xs text-mid hover:text-primary border border-border rounded-lg px-3 py-2 bg-white transition-colors">
            ← Önceki
          </a>
        )}
        {nextWeek && (
          <a href={`${base}hafta/${nextWeek.slug}`} class="flex items-center gap-1 text-xs text-white bg-primary hover:bg-primary/90 rounded-lg px-3 py-2 transition-colors">
            Sonraki →
          </a>
        )}
      </div>
    </div>
  </div>

  <!-- SUNUM / IFRAME -->
  <div class="rounded-2xl overflow-hidden border border-border shadow-md mb-6 bg-dark relative">
    <div class="flex items-center gap-2 px-4 py-2 bg-dark border-b border-white/10">
      <div class="flex gap-1.5">
        <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
        <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
      </div>
      <span class="text-xs text-gray-400 ml-2">📊 {week.pptxFile}</span>
    </div>
    {pdfUrl ? (
      <iframe
        src={pdfUrl}
        width="100%"
        height="560"
        frameborder="0"
        class="w-full block bg-white"
        loading="lazy"
        title={`Uygulama ${week.id} Sunumu`}
      />
    ) : (
      <div class="bg-dark/80 flex flex-col items-center justify-center text-center p-8 min-h-[350px]">
        <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mb-4 text-3xl">📊</div>
        <h3 class="text-white text-lg font-bold mb-2">Sunum Yüklenemedi</h3>
        <p class="text-gray-400 text-sm max-w-md">
          Bu haftanın Google Drive sunum ID'si (pptxDriveId) henüz yapılandırılmamıştır. 
          Drive klasörü senkronize edildikten sonra sunum burada görüntülenecektir.
        </p>
      </div>
    )}
  </div>

  <!-- SEKMELER: Konular / Ödevler / Notebook / Kaynaklar -->
  <div class="mb-6">
    <!-- Tab buttons -->
    <div class="flex gap-1 border-b border-border mb-4" id="tabs">
      {[
        { key: 'konular', label: '📋 Konular',   count: week.topics.length },
        { key: 'odevler', label: '📝 Çalışmalar & Ödevler',   count: week.assignments.length },
        { key: 'notebook', label: '💻 Notebook\'lar', count: week.notebooks.length },
        { key: 'kaynaklar', label: '📚 Kaynaklar', count: week.resources.length },
      ].map(tab => (
        <button
          data-tab={tab.key}
          onclick="switchTab(this)"
          class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-mid hover:text-primary transition-colors -mb-px"
        >
          {tab.label}
          <span class="ml-1 text-[10px] bg-border rounded-full px-1.5 py-0.5">{tab.count}</span>
        </button>
      ))}
    </div>

    <!-- Konular -->
    <div data-panel="konular" class="tab-panel">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        {week.topics.map((topic, i) => (
          <div class="flex items-start gap-3 bg-white rounded-lg border border-border p-3">
            <span class="shrink-0 w-6 h-6 rounded-full bg-accent/10 text-accent text-xs font-bold flex items-center justify-center">{i + 1}</span>
            <span class="text-sm text-dark leading-snug">{topic}</span>
          </div>
        ))}
      </div>
      {week.libraries.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2 items-center">
          <span class="text-xs text-mid font-medium">Kütüphaneler & Araçlar:</span>
          {week.libraries.map(lib => (
            <code class="text-xs bg-dark text-green-300 rounded px-2 py-0.5 font-mono">{lib}</code>
          ))}
        </div>
      )}
    </div>

    <!-- Ödevler -->
    <div data-panel="odevler" class="tab-panel hidden">
      <div class="space-y-3">
        {week.assignments.map((a, i) => (
          <div class="flex items-start gap-3 bg-warmBg rounded-lg border border-border p-4">
            <span class="shrink-0 w-7 h-7 rounded-full bg-secondary text-white text-xs font-bold flex items-center justify-center">{i + 1}</span>
            <p class="text-sm text-dark leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Notebook'lar -->
    <div data-panel="notebook" class="tab-panel hidden">
      <div class="space-y-3">
        {week.notebooks.map((nb, i) => (
          <div class="flex items-start gap-4 bg-dark text-white rounded-xl p-4">
            <span class="shrink-0 w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center text-green-400 font-mono text-sm font-bold">{i + 1}</span>
            <div class="flex-1">
              <code class="text-green-300 text-sm font-mono block mb-1">{nb.name}</code>
              <p class="text-gray-400 text-xs mb-2">{nb.desc}</p>
              <div class="flex flex-wrap gap-2">
                {nb.url ? (
                  <>
                    <a href={nb.url} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-md bg-white/10 text-xs text-gray-300 hover:text-white hover:bg-white/20 transition-colors">
                      Drive'da Aç
                    </a>
                    <a href={`https://colab.research.google.com/drive/${nb.url.split('/drive/')[1] || ''}`} target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-md bg-yellow-500/20 text-xs text-yellow-300 hover:text-yellow-100 hover:bg-yellow-500/30 transition-colors">
                      Colab'da Çalıştır
                    </a>
                  </>
                ) : (
                  <span class="text-xs text-gray-500 italic">Google Drive URL henüz eklenmemiştir.</span>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
      {week.datasets.length > 0 && (
        <div class="mt-4">
          <p class="text-xs font-medium text-mid mb-2">Veri Setleri:</p>
          <div class="flex flex-wrap gap-2">
            {week.datasets.map(ds => (
              <span class="text-xs bg-accent/10 text-accent border border-accent/20 rounded-full px-3 py-1">{ds}</span>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- Kaynaklar -->
    <div data-panel="kaynaklar" class="tab-panel hidden">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {week.resources.map(r => (
          <a
            href={r.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 bg-white border border-border rounded-xl p-4 hover:border-accent hover:shadow-sm transition-all group"
          >
            <span class="w-8 h-8 rounded-lg bg-accent/10 flex items-center justify-center text-accent text-base">🔗</span>
            <div>
              <p class="text-sm font-medium text-dark group-hover:text-accent transition-colors">{r.label}</p>
              <p class="text-[10px] text-mid truncate max-w-[200px]">{r.url}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>

</Layout>

<script is:inline>
function switchTab(btn) {
  var key = btn.getAttribute('data-tab');
  // Update buttons
  document.querySelectorAll('.tab-btn').forEach(function(b) {
    b.classList.remove('border-primary', 'text-primary');
    b.classList.add('border-transparent', 'text-mid');
  });
  btn.classList.add('border-primary', 'text-primary');
  btn.classList.remove('border-transparent', 'text-mid');
  // Update panels
  document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.add('hidden'); });
  var panel = document.querySelector('[data-panel="' + key + '"]');
  if (panel) panel.classList.remove('hidden');
}
// Activate first tab on load
document.addEventListener('DOMContentLoaded', function() {
  var first = document.querySelector('.tab-btn');
  if (first) switchTab(first);
});
</script>

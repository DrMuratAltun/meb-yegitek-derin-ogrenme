---
import Layout from '../layouts/Layout.astro';
import { weeks } from '../data/curriculum';

const base = import.meta.env.BASE_URL;

const sections = [
  { label: 'DERİN ÖĞRENME TEMELLERİ', color: 'accent',    weeks: weeks.filter(w => w.id <= 5), hours: 21 },
  { label: 'KERAS İLE UYGULAMA',      color: 'secondary', weeks: weeks.filter(w => w.id >= 6 && w.id <= 7), hours: 11 },
  { label: 'İLERİ BİLGİSAYARLI GÖRÜ', color: 'primary',   weeks: weeks.filter(w => w.id >= 8), hours: 12 },
];

const journeyBadge: Record<string, string> = {
  accent:    'bg-accent text-white',
  secondary: 'bg-secondary text-white',
  primary:   'bg-primary text-white',
};
const journeyBorder: Record<string, string> = {
  accent:    'border-accent/20 hover:border-accent/40',
  secondary: 'border-secondary/20 hover:border-secondary/40',
  primary:   'border-primary/20 hover:border-primary/40',
};

const colorMap: Record<string, string> = {
  accent:    'border-accent bg-accent/5 hover:bg-accent/10',
  secondary: 'border-secondary bg-secondary/5 hover:bg-secondary/10',
  primary:   'border-primary bg-primary/5 hover:bg-primary/10',
};
const badgeMap: Record<string, string> = {
  accent:    'bg-accent text-white',
  secondary: 'bg-secondary text-white',
  primary:   'bg-primary text-white',
};
const textMap: Record<string, string> = {
  accent:    'text-accent',
  secondary: 'text-secondary',
  primary:   'text-primary',
};
---

<Layout title="Eğitim Serisi Özeti">
  <!-- HERO -->
  <div class="rounded-2xl bg-dark text-white p-8 mb-8 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background: radial-gradient(circle at 70% 50%, #C97B5A 0%, transparent 60%)"></div>
    <div class="relative">
      <div class="flex items-start justify-between flex-wrap gap-4">
        <div>
          <p class="text-secondary text-sm font-medium uppercase tracking-widest mb-2">MEB YEĞİTEK</p>
          <h1 class="text-3xl font-bold mb-2">Derin Öğrenme Eğitim Serisi</h1>
          <p class="text-gray-400 text-sm">Öğretmenler ve Eğitimciler İçin Uygulamalı Yapay Zeka · Dr. Murat Altun</p>
        </div>
        <div class="flex gap-4 text-center">
          <div class="bg-white/10 rounded-xl px-5 py-3">
            <div class="text-3xl font-bold text-secondary">44</div>
            <div class="text-xs text-gray-400 mt-1">Toplam Saat</div>
          </div>
          <div class="bg-white/10 rounded-xl px-5 py-3">
            <div class="text-3xl font-bold text-accent">9</div>
            <div class="text-xs text-gray-400 mt-1">Uygulama</div>
          </div>
          <div class="bg-white/10 rounded-xl px-5 py-3">
            <div class="text-3xl font-bold text-orange-300">3</div>
            <div class="text-xs text-gray-400 mt-1">Bölüm</div>
          </div>
        </div>
      </div>

      <!-- Özellikler -->
      <div class="mt-6 flex flex-wrap gap-3">
        <div class="flex items-center gap-2 bg-white/10 rounded-lg px-3 py-2 text-sm">
          <span class="text-secondary">▪</span> NumPy ile Sıfırdan Temeller
        </div>
        <div class="flex items-center gap-2 bg-white/10 rounded-lg px-3 py-2 text-sm">
          <span class="text-accent">▪</span> Keras ile Derin Öğrenme
        </div>
        <div class="flex items-center gap-2 bg-white/10 rounded-lg px-3 py-2 text-sm">
          <span class="text-orange-300">▪</span> Gradio ile Arayüz Dağıtımı
        </div>
      </div>
    </div>
  </div>

  <!-- BÖLÜMLER -->
  {sections.map(section => (
    <div class="mb-10">
      <div class={`flex items-center gap-3 mb-4`}>
        <span class={`inline-block w-1 h-6 rounded-full ${badgeMap[section.color]}`}></span>
        <h2 class={`text-sm font-bold uppercase tracking-widest ${textMap[section.color]}`}>{section.label}</h2>
        <span class="text-xs text-mid bg-border/60 rounded-full px-2 py-0.5">{section.hours} saat</span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
        {section.weeks.map(week => (
          <a
            href={`${base}hafta/${week.slug}`}
            class={`group block rounded-xl border-l-4 p-4 transition-all ${colorMap[section.color]} border border-border`}
          >
            <div class="flex items-start justify-between gap-2 mb-3">
              <span class={`text-xs font-bold px-2 py-0.5 rounded-full ${badgeMap[section.color]}`}>UYGULAMA {week.id}</span>
              <span class="text-xs text-mid">{week.hours} saat</span>
            </div>
            <h3 class="font-semibold text-dark text-sm leading-snug mb-2 group-hover:text-primary transition-colors">{week.title}</h3>
            <p class="text-xs text-mid mb-3">{week.subtitle}</p>
            <div class="flex flex-wrap gap-1">
              {week.libraries.slice(0, 3).map(lib => (
                <span class="text-[10px] bg-white/70 border border-border rounded px-1.5 py-0.5 text-mid font-mono">{lib}</span>
              ))}
              {week.libraries.length > 3 && (
                <span class="text-[10px] text-mid">+{week.libraries.length - 3}</span>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  ))}

  <!-- PLATFORMLAR -->
  <div class="mt-10 mb-8">
    <div class="flex items-center gap-3 mb-4">
      <span class="inline-block w-1 h-6 rounded-full bg-primary"></span>
      <h2 class="text-sm font-bold uppercase tracking-widest text-primary">Kullanılan Platformlar ve Araçlar</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {[
        { name: 'Google Colab',  emoji: '🟡', desc: 'Bulutta ücretsiz Python notebook ve GPU erişimi', url: 'https://colab.research.google.com/' },
        { name: 'TensorFlow & Keras', emoji: '⚙️', desc: 'Yapay sinir ağları ve derin öğrenme modelleri oluşturma', url: 'https://keras.io/' },
        { name: 'GitHub',        emoji: '⚫', desc: 'Kod barındırma, versiyon kontrolü ve portföy', url: 'https://github.com/' },
        { name: 'NumPy & Matplotlib', emoji: '📊', desc: 'Veri manipülasyonu ve grafik görselleştirme', url: 'https://numpy.org/' },
        { name: 'Gradio',        emoji: '🚀', desc: 'Birkaç satır kodla yapay zeka web demosu oluşturma', url: 'https://gradio.app/' },
        { name: 'Google Drive',  emoji: '📁', desc: 'Sunumlar ve notebook senkronizasyonu', url: 'https://drive.google.com/' },
      ].map(p => (
        <a href={p.url} target="_blank" rel="noopener" class="group flex items-start gap-3 bg-white rounded-xl border border-border p-4 hover:border-primary/40 hover:shadow-sm transition-all">
          <span class="text-2xl shrink-0">{p.emoji}</span>
          <div>
            <p class="font-semibold text-dark text-sm group-hover:text-primary transition-colors">{p.name}</p>
            <p class="text-xs text-mid mt-1 leading-snug">{p.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- ÖĞRENME YOLCULUĞU -->
  <div class="mb-8 rounded-2xl border border-border bg-white p-6">
    <div class="flex items-center gap-3 mb-5">
      <span class="inline-block w-1 h-6 rounded-full bg-secondary"></span>
      <h2 class="text-sm font-bold uppercase tracking-widest text-secondary">Öğrenme Yolculuğu</h2>
    </div>
    <p class="text-sm text-mid mb-5 leading-relaxed">
      Uygulamalı 9 adımdan oluşan derin öğrenme yolculuğunda kullanılan teknolojiler ve kazanımlar:
    </p>

    <div class="space-y-3">
      {[
        { weeks: 'Adım 1-5', module: 'Derin Öğrenme Temelleri (Sıfırdan NumPy)', color: 'accent',    libs: ['Python 3', 'Google Colab', 'NumPy', 'Matplotlib'] },
        { weeks: 'Adım 6-7', module: 'Keras ve Web Arayüz Dağıtımı (Gradio)',  color: 'secondary', libs: ['TensorFlow', 'Keras Sequential', 'Gradio', 'scikit-learn'] },
        { weeks: 'Adım 8-9', module: 'İleri Bilgisayarlı Görü (CNN & Transfer Learning)', color: 'primary',   libs: ['CNN', 'Conv2D', 'MaxPooling2D', 'Pretrained MobileNetV2', 'Data Augmentation'] },
      ].map(row => (
        <div class={`flex items-start gap-4 rounded-xl border bg-warmBg/40 p-3 transition-colors ${journeyBorder[row.color]}`}>
          <div class="shrink-0 flex flex-col items-center min-w-[70px]">
            <span class={`text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded ${journeyBadge[row.color]}`}>{row.weeks}</span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-dark text-sm mb-1.5">{row.module}</p>
            <div class="flex flex-wrap gap-1">
              {row.libs.map(lib => (
                <code class="text-[11px] bg-dark text-green-300 rounded px-2 py-0.5 font-mono">{lib}</code>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-5 pt-5 border-t border-border flex flex-wrap gap-3 text-xs text-mid">
      <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-accent inline-block"></span> Derin Öğrenme Temelleri (21 saat)</span>
      <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-secondary inline-block"></span> Keras ile Uygulama (11 saat)</span>
      <span class="flex items-center gap-1.5"><span class="w-2 h-2 rounded-full bg-primary inline-block"></span> İleri Bilgisayarlı Görü (12 saat)</span>
    </div>
  </div>

  <!-- KATILIM KOŞULLARI -->
  <div class="mb-8 rounded-2xl bg-warmBg border border-border p-6">
    <div class="flex items-center gap-3 mb-4">
      <span class="inline-block w-1 h-6 rounded-full bg-accent"></span>
      <h2 class="text-sm font-bold uppercase tracking-widest text-accent">Katılım Koşulları ve Yaklaşım</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      {[
        { icon: '💻', title: 'Bulut Tabanlı Çalışma', desc: 'Google Colab kullanıldığı için güçlü bir donanıma ihtiyacınız yoktur. Sadece internet tarayıcısı yeterlidir.' },
        { icon: '🐍', title: 'Python Önkoşulu', desc: 'Temel Python (değişkenler, fonksiyonlar, döngüler) bilgisi gereklidir. Matematik detayları analojilerle aktarılır.' },
        { icon: '🔍', title: 'Kara Kutuyu Açmak', desc: 'İlk bölümde hazır kütüphane kullanmadan NumPy ile nörondan optimizasyona kadar sıfırdan formüller kodlanır.' },
        { icon: '🚀', title: 'Gerçekçi Uygulamalar', desc: 'İkinci ve üçüncü bölümlerde Keras ve Gradio kullanılarak gerçek dünya problemlerine çözümler dağıtılır.' },
      ].map(req => (
        <div class="flex items-start gap-3 bg-white rounded-xl border border-border p-4">
          <span class="text-2xl shrink-0">{req.icon}</span>
          <div>
            <p class="font-semibold text-dark text-sm mb-1">{req.title}</p>
            <p class="text-xs text-mid leading-relaxed">{req.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>

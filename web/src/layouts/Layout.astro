---
import { weeks } from '../data/curriculum';

interface Props {
  title: string;
  description?: string;
  activeWeekId?: number;
  canonical?: string;
}

const { title, description, activeWeekId, canonical } = Astro.props;
const base = import.meta.env.BASE_URL;
const siteUrl = 'https://drmurataltun.github.io/meb-yegitek-derin-ogrenme';

const metaTitle = `${title} — Derin Öğrenme Eğitim Serisi · Dr. Murat Altun`;
const metaDesc = description ?? 'MEB YEĞİTEK öğretmen ve eğitimcileri için uygulamalı yapay zeka ve derin öğrenme eğitim serisi. Sıfırdan nörondan CNN ve Transfer Öğrenmeye kadar 9 uygulamalı adım.';
const canonicalUrl = canonical ?? siteUrl;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'Derin Öğrenme Eğitim Serisi',
  description: metaDesc,
  provider: {
    '@type': 'Person',
    name: 'Dr. Murat Altun',
    url: 'https://github.com/DrMuratAltun',
  },
  educationalLevel: 'Beginner to Intermediate',
  inLanguage: 'tr',
  numberOfCredits: 44,
  courseMode: 'online',
  url: siteUrl,
};
---

<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#5B2C1E" />

  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <link rel="apple-touch-icon" href={`${base}favicon.svg`} />

  <!-- Primary Meta -->
  <title>{metaTitle}</title>
  <meta name="description" content={metaDesc} />
  <meta name="author" content="Dr. Murat Altun" />
  <meta name="keywords" content="derin öğrenme, yapay zeka, sinir ağları, cnn, transfer learning, tensorflow, keras, python, numpy, gradio, yegitek, meb, Dr. Murat Altun" />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={metaTitle} />
  <meta property="og:description" content={metaDesc} />
  <meta property="og:locale" content="tr_TR" />
  <meta property="og:site_name" content="Derin Öğrenme Eğitim Serisi" />
  <meta property="og:image" content={`${siteUrl}/og-image.jpg`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Derin Öğrenme Eğitim Serisi — Dr. Murat Altun" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={metaTitle} />
  <meta name="twitter:description" content={metaDesc} />
  <meta name="twitter:image" content={`${siteUrl}/og-image.jpg`} />
  <meta name="twitter:image:alt" content="Derin Öğrenme Eğitim Serisi — Dr. Murat Altun" />

  <!-- Robots -->
  <meta name="robots" content="index, follow" />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3 { font-family: 'Georgia', 'Times New Roman', serif; }
  </style>
</head>
<body class="bg-cream min-h-screen">

  <!-- TOP HEADER -->
  <header class="bg-dark text-white shadow-lg sticky top-0 z-50">
    <div class="max-w-screen-xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href={base} class="flex items-center gap-3 hover:opacity-90 transition-opacity">
        <div class="w-9 h-9 rounded-lg bg-secondary flex items-center justify-center text-white font-bold text-xs">MEB</div>
        <div>
          <div class="font-semibold text-sm leading-tight">Derin Öğrenme Eğitim Serisi</div>
          <div class="text-xs text-gray-400">MEB YEĞİTEK · 44 Saat · Dr. Murat Altun</div>
        </div>
      </a>
      <div class="hidden md:flex items-center gap-4 text-sm">
        <span class="px-2 py-1 rounded bg-accent/20 text-accent border border-accent/30 text-xs">Temeller (1-5)</span>
        <span class="px-2 py-1 rounded bg-secondary/20 text-secondary border border-secondary/30 text-xs">Keras (6-7)</span>
        <span class="px-2 py-1 rounded bg-primary/20 text-orange-300 border border-primary/30 text-xs">Bilgisayarlı Görü (8-9)</span>
      </div>
    </div>
  </header>

  <div class="flex max-w-screen-xl mx-auto">

    <!-- SIDEBAR -->
    <aside class="w-64 shrink-0 hidden lg:block sticky top-[57px] self-start h-[calc(100vh-57px)] overflow-y-auto border-r border-border bg-warmBg">
      <nav class="py-4" aria-label="Hafta navigasyonu">
        <a href={base} class={`flex items-center gap-2 px-4 py-2 text-sm font-medium transition-colors ${!activeWeekId ? 'bg-primary text-white' : 'text-mid hover:text-primary hover:bg-border/50'}`}>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Seri Özeti
        </a>

        <!-- Bölüm 1 -->
        <div class="px-4 pt-4 pb-1">
          <span class="text-[10px] font-bold uppercase tracking-widest text-accent">Bölüm 1 — Temeller</span>
        </div>
        {weeks.filter(w => w.id <= 5).map(w => (
          <a
            href={`${base}hafta/${w.slug}`}
            aria-current={activeWeekId === w.id ? 'page' : undefined}
            class={`flex items-center gap-2 px-4 py-2 text-sm transition-colors ${activeWeekId === w.id ? 'bg-accent text-white font-semibold' : 'text-mid hover:text-accent hover:bg-border/50'}`}
          >
            <span class={`w-6 h-6 rounded-full flex items-center justify-center text-xs shrink-0 ${activeWeekId === w.id ? 'bg-white/20' : 'bg-accent/10 text-accent'}`}>{w.id}</span>
            <span class="truncate leading-snug">{w.title}</span>
          </a>
        ))}

        <!-- Bölüm 2 -->
        <div class="px-4 pt-4 pb-1">
          <span class="text-[10px] font-bold uppercase tracking-widest text-secondary">Bölüm 2 — Keras</span>
        </div>
        {weeks.filter(w => w.id >= 6 && w.id <= 7).map(w => (
          <a
            href={`${base}hafta/${w.slug}`}
            aria-current={activeWeekId === w.id ? 'page' : undefined}
            class={`flex items-center gap-2 px-4 py-2 text-sm transition-colors ${activeWeekId === w.id ? 'bg-secondary text-white font-semibold' : 'text-mid hover:text-secondary hover:bg-border/50'}`}
          >
            <span class={`w-6 h-6 rounded-full flex items-center justify-center text-xs shrink-0 ${activeWeekId === w.id ? 'bg-white/20' : 'bg-secondary/10 text-secondary'}`}>{w.id}</span>
            <span class="truncate leading-snug">{w.title}</span>
          </a>
        ))}

        <!-- Bölüm 3 -->
        <div class="px-4 pt-4 pb-1">
          <span class="text-[10px] font-bold uppercase tracking-widest text-primary">Bölüm 3 — Bilgisayarlı Görü</span>
        </div>
        {weeks.filter(w => w.id >= 8).map(w => (
          <a
            href={`${base}hafta/${w.slug}`}
            aria-current={activeWeekId === w.id ? 'page' : undefined}
            class={`flex items-center gap-2 px-4 py-2 text-sm transition-colors ${activeWeekId === w.id ? 'bg-primary text-white font-semibold' : 'text-mid hover:text-primary hover:bg-border/50'}`}
          >
            <span class={`w-6 h-6 rounded-full flex items-center justify-center text-xs shrink-0 ${activeWeekId === w.id ? 'bg-white/20' : 'bg-primary/10 text-primary'}`}>{w.id}</span>
            <span class="truncate leading-snug">{w.title}</span>
          </a>
        ))}
      </nav>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="flex-1 min-w-0 p-6">
      <slot />
    </main>

  </div>

  <!-- FOOTER -->
  <footer class="bg-dark text-gray-400 mt-12 border-t-4 border-secondary">
    <div class="max-w-screen-xl mx-auto px-6 py-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- Hakkında -->
        <div>
          <h3 class="text-white font-semibold text-sm mb-3">Derin Öğrenme Eğitim Serisi</h3>
          <p class="text-xs leading-relaxed">
            MEB YEĞİTEK bünyesinde öğretmenlerin yapay zeka ve derin öğrenme yetkinliklerini artırmak üzere Dr. Murat Altun tarafından hazırlanmış uygulamalı eğitim serisi.
          </p>
        </div>

        <!-- Kaynak ve İletişim -->
        <div>
          <h3 class="text-white font-semibold text-sm mb-3">Bağlantılar</h3>
          <ul class="space-y-2 text-xs">
            <li>
              <a href="https://github.com/DrMuratAltun/meb-yegitek-derin-ogrenme" target="_blank" rel="noopener" class="hover:text-secondary transition-colors inline-flex items-center gap-1.5">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                GitHub Kaynak Deposu
              </a>
            </li>
            <li>
              <a href="https://yapayzekaokulum.com" target="_blank" rel="noopener" class="hover:text-secondary transition-colors inline-flex items-center gap-1.5">
                🎓 Yapay Zeka Okulum
              </a>
            </li>
          </ul>
        </div>

      </div>

      <div class="border-t border-gray-700 mt-8 pt-6 text-center text-xs">
        <p>© 2026 Dr. Murat Altun — MEB YEĞİTEK Derin Öğrenme Eğitim Serisi</p>
      </div>
    </div>
  </footer>

</body>
</html>
